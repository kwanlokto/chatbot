# ── LLM Provider ──────────────────────────────────────────
# "ollama"       → local Ollama instance (default for local dev)
# "huggingface"  → HuggingFace Inference API (for cloud deployment)
LLM_PROVIDER=ollama

# ── Ollama (local dev) ─────────────────────────────────────
OLLAMA_URL=http://localhost:11434
GEN_MODEL_NAME=llama3.2

# ── HuggingFace (cloud deployment) ────────────────────────
# Get a free token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
HF_GEN_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# ── ChromaDB ───────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
